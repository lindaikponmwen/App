{
  "model": {
    "model_type": "custom_ode",
    "custom_ode": {
      "n_compartments": 2,
      "parameters": ["CL", "V", "KA"],
      "equations": [
        "-KA * A[0]",
        "KA * A[0] - (CL/V) * A[1]"
      ],
      "observation_compartment": 1,
      "observation_scaling": "V"
    }
  },
  "data": {
    "file": "examples/one_compartment_sample.csv",
    "id_column": "ID",
    "time_column": "TIME",
    "dv_column": "DV",
    "amt_column": "AMT",
    "evid_column": "EVID",
    "covariates": []
  },
  "parameters": {
    "theta": {
      "CL": 5.0,
      "V": 50.0,
      "KA": 1.0
    },
    "theta_names": {
      "CL": "Clearance (L/h)",
      "V": "Volume of distribution (L)",
      "KA": "Absorption rate constant (1/h)"
    },
    "omega": {
      "CL": 0.1,
      "V": 0.1,
      "KA": 0.1
    },
    "omega_names": {
      "CL": "Inter-individual variability on CL",
      "V": "Inter-individual variability on V",
      "KA": "Inter-individual variability on KA"
    },
    "sigma": 0.5,
    "error_model": "combined",
    "sigma_proportional": 0.1,
    "constraints": {
      "theta_lower": [0.1, 1.0, 0.01],
      "theta_upper": [50.0, 500.0, 10.0],
      "omega_lower": null,
      "omega_upper": null,
      "theta_fixed": null,
      "omega_fixed": null,
      "sigma_fixed": null
    }
  },
  "estimation": {
    "method": "SAEM",
    "n_burn_in": 100,
    "n_iter": 300,
    "n_chains": 3,
    "seed": 12345
  },
  "output": {
    "directory": "output_custom_ode_1comp",
    "save_individual_parameters": true,
    "save_predictions": true,
    "generate_plots": false
  }
}
